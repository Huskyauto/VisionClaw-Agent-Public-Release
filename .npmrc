# legacy-peer-deps: required for @anthropic-ai/claude-agent-sdk, which peer-requires
# zod ^4.0.0 while the platform is on zod 3.25.x (drizzle-zod ecosystem). zod 3.25+
# ships the zod/v4 subpath the SDK actually imports at runtime, so the peer conflict
# is resolver-only. Remove this once the platform migrates to zod 4.
legacy-peer-deps=true
