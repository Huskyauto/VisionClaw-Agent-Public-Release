# ============================================================================
# VisionClaw Agent Platform — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
# On Replit, set these as Secrets in the Secrets tab instead.
# ============================================================================

# ─── REQUIRED ───────────────────────────────────────────────────────────────

# PostgreSQL connection string (provided automatically on Replit)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Session encryption key (generate with: openssl rand -hex 32)
SESSION_SECRET=your-random-session-secret-here

# ─── AI PROVIDERS (at least one required) ───────────────────────────────────

# OpenAI (direct key or Replit AI integration)
OPENAI_API_KEY=sk-...

# Anthropic (for Claude models)
ANTHROPIC_API_KEY=sk-ant-...

# xAI (for Grok models)
XAI_API_KEY=xai-...

# OpenRouter (multi-model gateway, used as fallback)
OPENROUTER_API_KEY=sk-or-...

# Google Gemini (configured via Replit integration, or set manually)
# GOOGLE_API_KEY=...

# ─── SERVICES ───────────────────────────────────────────────────────────────

# Browserless.io — PDF generation and browser automation
BROWSERLESS_API_KEY=your-browserless-key

# ElevenLabs — Text-to-speech
ELEVENLABS_API_KEY=your-elevenlabs-key

# Firecrawl — Web scraping and crawling
FIRECRAWL_API_KEY=fc-...

# ─── PAYMENTS (optional) ───────────────────────────────────────────────────

# Stripe
STRIPE_LIVE_SECRET_KEY=sk_live_...
STRIPE_LIVE_PUBLISHABLE_KEY=pk_live_...

# Coinbase Commerce
COINBASE_COMMERCE_API_KEY=your-coinbase-key
COINBASE_COMMERCE_PROJECT_ID=your-project-id
COINBASE_CDP_API_KEY_ID=your-cdp-key

# ─── X/TWITTER (optional) ──────────────────────────────────────────────────

X_API_KEY=your-x-api-key
X_API_SECRET=your-x-api-secret
X_ACCESS_TOKEN=your-access-token
X_ACCESS_TOKEN_SECRET=your-access-token-secret

# ─── COMMUNICATIONS (optional) ─────────────────────────────────────────────

# Discord Bot
# DISCORD_BOT_TOKEN=your-discord-token

# Telegram Bot
# TELEGRAM_BOT_TOKEN=your-telegram-token

# ─── SITE BRANDING (recommended) ─────────────────────────────────────

# Platform display name (shown in UI header, emails, PDFs)
SITE_PLATFORM_NAME=VisionClaw
SITE_COMPANY_NAME=Your Company Name
SITE_OWNER_EMAIL=you@example.com
SITE_AGENT_NAME=Felix

# ─── ADMIN (optional) ──────────────────────────────────────────────────────

# Admin PIN for privileged operations (4+ digits)
ADMIN_PIN=0000

# Owner info for automated reports
OWNER_NAME=Your Name
OWNER_EMAILS=you@example.com
ADMIN_ALERT_EMAIL=you@example.com

# R103 — Owner email digest (rate-limit alerts to once-a-day digest)
# digest = batch all owner-bound emails into one daily summary (default)
# immediate = send every email as it happens (pre-R103 behavior)
# silent = drop owner-bound emails entirely (no digest either)
# OWNER_EMAIL_MODE=digest
# OWNER_DIGEST_HOUR_UTC=13          # 13:00 UTC = 8am US Central
# OWNER_DIGEST_RECIPIENTS=          # CSV of additional addresses to treat as "owner"

# Production domain (for QR codes and PDF footers)
PRODUCTION_DOMAIN=your-domain.com

# Logo URLs for slides and presentations (optional, Google Drive direct-link format)
# SITE_LOGO_URL=https://lh3.googleusercontent.com/d/YOUR_FILE_ID
# SITE_QR_LOGO_URL=https://lh3.googleusercontent.com/d/YOUR_FILE_ID

# ─── GITHUB / SELF-MODIFICATION (optional, READ THIS FIRST) ────────────────
#
# ⚠️  GITHUB_TOKEN grants the running platform write access to its own source
#     repository. The agents perform their own maintenance commits when this
#     is set. This is by design for the original author's solo workflow, but
#     it is a non-obvious capability for forkers.
#
# Implications you must accept before setting GITHUB_TOKEN:
#   • An agent with shell access that is successfully prompt-injected can,
#     in principle, modify source code and force-push.
#   • The push script's secret-scan blocks credential leakage but does NOT
#     validate that arbitrary code edits are intended.
#   • If you do not want this capability, leave both vars unset — the push
#     scripts no-op cleanly when GITHUB_TOKEN is missing.
#
# Recommended for forkers: leave commented out unless you specifically want
# automated source-code maintenance commits. See SECURITY.md → "Self-modification
# capability" for the full threat model.
#
# GITHUB_TOKEN=ghp_...
# GIT_COMMIT_EMAIL=you@example.com

# ─── WHATSAPP (optional, ToS RISK — read before enabling) ───────────────────
#
# ⚠️  VisionClaw's WhatsApp integration uses @whiskeysockets/baileys, a
#     reverse-engineered WhatsApp Web client. Meta's Terms of Service do
#     NOT sanction this. Accounts using unofficial clients can be banned
#     without notice — and Meta has been increasing enforcement.
#
# DO NOT connect a WhatsApp account that:
#   • Belongs to a paying client (you cannot afford their ban).
#   • Belongs to your business main number.
#   • Is your personal phone you actually use.
#
# Use a throwaway / dedicated number you can afford to lose. For commercial
# or client-facing use, prefer the official WhatsApp Business Cloud API
# (server/whatsapp-cloud.ts is the planned bridge — currently stub).
#
# See SECURITY.md → "Compliance & ToS risks" for the full warning.
#
# WHATSAPP_ENABLED=0
# WHATSAPP_PHONE_NUMBER=+1...

# ─── YOUTUBE (optional) ────────────────────────────────────────────────────

# YOUTUBE_CLIENT_ID=your-client-id
# YOUTUBE_CLIENT_SECRET=your-client-secret
# YOUTUBE_REFRESH_TOKEN=your-refresh-token

# ─── SLACK (optional, R98.26 — agent invocation surface) ───────────────────
# Required to enable /api/slack/commands + /api/slack/events.
# Without these, the routes return 503 and /api/slack/health reports enabled:false.
# Slack app config: https://api.slack.com/apps → Basic Info → Signing Secret
# Bot token: OAuth & Permissions → Bot User OAuth Token (xoxb-...)
# SLACK_SIGNING_SECRET=
# SLACK_BOT_TOKEN=
# Slack workspace allowlist (R98.26.6) — pin ingress to your team_id to prevent
# pivot if the signing secret ever leaks. Comma-separated for multi-workspace.
# All three are optional; if all unset, allowlist fails OPEN with a one-time
# log warning. If ANY is set, mismatch → 403.
# SLACK_ALLOWED_TEAM_ID=
# R98.27.2 — User-level ACL on top of the workspace allowlist. Comma-separated
# Slack user IDs (e.g. U0123ABC,U0456DEF) authorized to drive ADMIN_TENANT_ID.
# Unset = any user in the allowed workspace can invoke (single-operator
# fallback, logged loud at boot). Set = deny-by-default; rejected user IDs are
# audit-logged so you can grant access by appending the U… id printed in
# `[slack] ... rejected user=...`.
SLACK_ALLOWED_USER_ID=
# SLACK_ALLOWED_ENTERPRISE_ID=
# SLACK_ALLOWED_APP_ID=

# ─── COHERE RERANK (optional, R98.27 — RAG quality lift) ───────────────────
# When set, the hybrid knowledge retriever (server/embeddings.ts
# vectorSearchKnowledge) reranks the RRF-fused candidate set with Cohere
# Rerank v3.5 before returning topK. Anthropic's Contextual Retrieval study
# shows rerank takes top-20 retrieval failure from -49% to -67% versus
# vector-only baseline.
#
# Without this var set, the retriever skips rerank and returns the RRF
# fusion directly (current behavior — strictly equal or better).
#
# Get a key: https://dashboard.cohere.com/api-keys (free tier covers
# generous trial volume).
#
# DATA EGRESS WARNING: when enabled, the title + content of the top
# 3*topK (min 15) candidate knowledge rows for EACH hybrid query is sent
# to Cohere's hosted API (https://api.cohere.com/v2/rerank). Do NOT
# enable on tenants whose knowledge corpus contains regulated data
# (PHI/PII/financial) without first reviewing Cohere's DPA. Leave unset
# to keep all retrieval fully on-prem.
# COHERE_API_KEY=
# Optional model override (default: rerank-v3.5).
# COHERE_RERANK_MODEL=rerank-v3.5

# Auto-contextualize chunk ceiling (R98.27, default 500). When add_doc is
# called with auto_contextualize=true, docs producing more than this many
# chunks skip LLM contextualization (degrades to caller-supplied context)
# so a runaway upload can't burn budget. ~$0.0001/chunk × 500 = $0.05/doc.
# DOC_AUTOCONTEXT_MAX_CHUNKS=500
